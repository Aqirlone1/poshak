# Copy to .env for local use. Never commit real secrets.
#
# Database (Neon: use the pooled connection string; sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Optional: Redis (only needed if you use Sidekiq or mount Sidekiq::Web with a live Redis)
REDIS_URL=redis://localhost:6379/1

# Host for URLs (local: localhost:3000 — production: your-app.onrender.com, no https)
APP_HOST=localhost:3000

# Mail (optional locally)
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Active Storage: set all three on production when using S3/R2; omit to use disk (see production.rb)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=

# Render / production-style static files + logging
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# Required in production if credentials are encrypted (contents of config/master.key — never commit the real value)
RAILS_MASTER_KEY=
