<section class="space-y-6">
  <div class="rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-violet-700">Product Detail</p>
    <h1 class="mt-1 text-3xl font-bold text-violet-950"><%= @product.name %></h1>
  </div>

  <div class="grid gap-8 md:grid-cols-2">
    <div class="rounded-2xl border border-neutral-200 bg-gradient-to-br from-fuchsia-100 via-violet-100 to-cyan-100 p-3 shadow-sm">
      <div class="aspect-[4/5] rounded-xl bg-white/60">
        <% if @product.primary_image&.image&.attached? %>
          <%= image_tag @product.primary_image.image, class: "h-full w-full rounded-xl object-cover" %>
        <% end %>
      </div>
    </div>
    <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
      <p class="text-2xl font-bold text-neutral-900">INR <%= @product.price %></p>
      <p class="mt-4 text-neutral-600"><%= @product.description %></p>

      <%= form_with url: add_item_cart_path, method: :post, class: "mt-6 space-y-3" do |f| %>
        <%= select_tag :product_variant_id, options_from_collection_for_select(@variants, :id, ->(v) { "#{v.size} / #{v.color} (#{v.stock_quantity} left)" }), class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
        <%= number_field_tag :quantity, 1, min: 1, class: "w-24 rounded-xl border border-neutral-300 px-3 py-2" %>
        <%= f.submit "Add to Cart", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-6 py-2 font-semibold text-white shadow" %>
      <% end %>
    </div>
  </div>
</section>
