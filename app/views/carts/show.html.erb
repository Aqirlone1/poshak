<section class="space-y-6">
  <div class="rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
    <h1 class="text-3xl font-bold text-violet-950">Your Cart</h1>
  </div>
  <% if @cart_items.empty? %>
    <p class="text-neutral-600">Your cart is empty.</p>
  <% else %>
    <div class="space-y-3">
      <% @cart_items.each do |item| %>
        <div class="flex items-center justify-between rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
          <div>
            <h3 class="font-semibold"><%= item.product.name %></h3>
            <p class="text-sm text-neutral-600"><%= item.product_variant.size %> / <%= item.product_variant.color %></p>
          </div>
          <div class="text-right">
            <p class="font-semibold">INR <%= item.total_price %></p>
            <%= button_to "Remove", remove_item_cart_path(cart_item_id: item.id), method: :delete, class: "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-600" %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-6">
      <%= link_to "Proceed to Checkout", checkout_address_path, class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-6 py-2 font-semibold text-white shadow" %>
    </div>
  <% end %>
</section>
