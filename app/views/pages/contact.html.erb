<div class="mx-auto max-w-3xl">
  <h1 class="mb-6 text-3xl font-semibold">Contact Us</h1>
  <div class="mb-6 rounded border p-4 text-sm text-neutral-700">
    <p>Email: support@poshak.example</p>
    <p>Phone: +91 90000 00000</p>
    <p>Hours: Mon-Sat, 10:00 AM - 7:00 PM</p>
  </div>

  <div class="rounded border p-4">
    <%= form_with url: contact_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :name, class: "w-full rounded border px-3 py-2" %>
      </div>
      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium" %>
        <%= f.email_field :email, class: "w-full rounded border px-3 py-2" %>
      </div>
      <div>
        <%= f.label :message, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_area :message, rows: 4, class: "w-full rounded border px-3 py-2" %>
      </div>
      <%= f.submit "Send Message", class: "rounded bg-black px-4 py-2 text-white" %>
    <% end %>
  </div>
</div>
