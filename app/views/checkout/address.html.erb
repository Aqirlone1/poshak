<section class="space-y-6">
  <div class="rounded-2xl border border-violet-100 bg-gradient-to-r from-violet-50 to-fuchsia-50 p-5">
    <h1 class="text-3xl font-bold text-violet-900">Select Address</h1>
    <p class="mt-1 text-sm text-violet-700">Choose a saved address or add a new one below.</p>
  </div>

  <% if @addresses.any? %>
    <%= form_with url: checkout_review_path, method: :post, class: "space-y-3 rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm" do |f| %>
      <% @addresses.each do |address| %>
        <label class="flex items-start gap-3 rounded-xl border border-neutral-200 bg-white p-4 transition hover:border-fuchsia-300 hover:shadow-md">
          <%= radio_button_tag :shipping_address_id, address.id, @selected_shipping_id.to_i == address.id, required: true, class: "mt-1" %>
          <span>
            <strong class="text-neutral-900"><%= address.full_name %></strong><br>
            <span class="text-neutral-600"><%= address.address_line1 %>, <%= address.city %>, <%= address.state %></span>
          </span>
        </label>
      <% end %>
      <%= f.submit "Continue to Review", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-6 py-2 font-semibold text-white shadow" %>
    <% end %>
  <% end %>

  <div class="rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-white to-fuchsia-50 p-5">
    <h2 class="text-xl font-bold text-violet-900">Add New Address</h2>
    <%= form_with model: @address, url: checkout_address_path, method: :post, class: "mt-4 grid gap-3 md:grid-cols-2" do |f| %>
      <div>
        <%= f.label :full_name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :full_name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :phone_number, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :phone_number, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :address_line1, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :address_line1, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :city, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :city, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :state, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :state, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :postal_code, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :postal_code, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :country, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :country, value: (@address.country.presence || "India"), class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= f.submit "Save Address & Continue", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-6 py-2 font-semibold text-white shadow" %>
      </div>
    <% end %>
  </div>
</section>
