<section class="space-y-6">
  <h1 class="text-3xl font-bold text-neutral-900">Review Order</h1>
  <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-wide text-fuchsia-700">Shipping To</p>
    <p class="mt-2 font-medium"><%= @shipping_address.full_name %> - <%= @shipping_address.phone_number %></p>
    <p class="text-neutral-600"><%= @shipping_address.address_line1 %>, <%= @shipping_address.city %>, <%= @shipping_address.state %></p>
  </div>

  <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-fuchsia-700">Items</p>
    <div class="space-y-2">
      <% @cart_items.each do |item| %>
        <div class="flex items-center justify-between rounded-lg bg-neutral-50 px-3 py-2">
          <span><%= item.product.name %> (<%= item.product_variant.size %>/<%= item.product_variant.color %>) x <%= item.quantity %></span>
          <span class="font-semibold">INR <%= item.total_price %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%= form_with url: checkout_place_order_path, method: :post do |f| %>
    <%= f.submit "Place COD Order", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-6 py-3 font-semibold text-white shadow-lg" %>
  <% end %>
</section>
