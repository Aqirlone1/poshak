<div class="max-w-2xl rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with model: [:account, address], class: "space-y-4" do |f| %>
    <% if address.errors.any? %>
      <div class="rounded border border-red-300 bg-red-50 p-3 text-sm text-red-700">
        <p class="font-semibold"><%= pluralize(address.errors.count, "error") %> prevented saving:</p>
        <ul class="mt-2 list-disc pl-5">
          <% address.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :full_name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :full_name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :phone_number, class: "mb-1 block text-sm font-medium" %>
        <%= f.telephone_field :phone_number, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :address_type, class: "mb-1 block text-sm font-medium" %>
        <%= f.select :address_type, Address.address_types.keys.map { |key| [key.titleize, key] }, {}, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :postal_code, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :postal_code, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :city, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :city, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :state, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :state, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :country, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :country, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
    </div>

    <div>
      <%= f.label :address_line1, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :address_line1, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :address_line2, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :address_line2, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :is_default %>
      Set as default address
    </label>

    <div class="flex gap-2">
      <%= f.submit class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
      <%= link_to "Cancel", account_addresses_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
    </div>
  <% end %>
</div>
