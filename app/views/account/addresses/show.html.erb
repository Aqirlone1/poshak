<div class="mb-6 flex items-center justify-between">
  <h1 class="text-3xl font-bold text-violet-950">Address Details</h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_account_address_path(@address), class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-4 py-2 font-semibold text-white" %>
    <%= link_to "Back", account_addresses_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
  </div>
</div>

<div class="max-w-xl rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <p class="font-medium"><%= @address.full_name %></p>
  <p class="text-sm"><%= @address.phone_number %></p>
  <p class="mt-2 text-sm"><%= @address.address_line1 %></p>
  <% if @address.address_line2.present? %><p class="text-sm"><%= @address.address_line2 %></p><% end %>
  <p class="text-sm"><%= @address.city %>, <%= @address.state %> <%= @address.postal_code %></p>
  <p class="text-sm"><%= @address.country %></p>
  <p class="mt-2 text-sm text-neutral-600">Type: <%= @address.address_type.titleize %></p>
</div>
