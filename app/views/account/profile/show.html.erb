<h1 class="mb-6 text-3xl font-bold text-violet-950">My Profile</h1>

<div class="max-w-2xl rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with model: @user, url: account_profile_path, method: :patch, class: "space-y-4" do |f| %>
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :first_name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :first_name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :last_name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :last_name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
    </div>
    <div>
      <%= f.label :phone_number, class: "mb-1 block text-sm font-medium" %>
      <%= f.telephone_field :phone_number, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>
    <%= f.submit "Update Profile", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
  <% end %>
</div>
