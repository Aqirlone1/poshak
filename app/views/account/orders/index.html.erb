<div class="mb-6 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">My Orders</h1>
</div>

<div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
  <table class="w-full">
    <thead class="bg-neutral-50 text-left text-sm">
      <tr>
        <th class="px-3 py-2">Order</th>
        <th class="px-3 py-2">Date</th>
        <th class="px-3 py-2">Total</th>
        <th class="px-3 py-2">Status</th>
        <th class="px-3 py-2">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y text-sm">
      <% @orders.each do |order| %>
        <% status_class = order.cancelled? ? "bg-red-100 text-red-700" : "bg-violet-100 text-violet-700" %>
        <tr>
          <td class="px-3 py-2"><%= link_to order.order_number, account_order_path(order), class: "font-semibold hover:text-fuchsia-700" %></td>
          <td class="px-3 py-2"><%= l(order.created_at.to_date) %></td>
          <td class="px-3 py-2"><%= number_to_currency(order.total_amount) %></td>
          <td class="px-3 py-2"><span class="rounded-full px-2 py-1 text-xs <%= status_class %>"><%= order.status.titleize %></span></td>
          <td class="px-3 py-2">
            <% if order.cancellable? %>
              <%= button_to "Cancel", cancel_account_order_path(order), method: :patch, data: { turbo_confirm: "Cancel this order?" }, class: "rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-600" %>
            <% else %>
              <span class="text-xs text-neutral-400">-</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
