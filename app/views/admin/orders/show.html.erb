<div class="mb-6 flex items-center justify-between rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">Order <%= @order.order_number %></h1>
  <%= link_to "Invoice", invoice_admin_order_path(@order), class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-4 py-2 font-semibold text-white" %>
</div>

<div class="mb-6 grid gap-4 md:grid-cols-2">
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Customer</h2>
    <p class="text-sm"><%= @order.user&.full_name.presence || "-" %></p>
    <p class="text-sm text-neutral-600"><%= @order.user&.email %></p>
    <p class="mt-2 text-sm text-neutral-600">Payment: <%= @order.payment_method %> (<%= @order.payment_status.titleize %>)</p>
  </div>
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Shipping Address</h2>
    <p class="text-sm"><%= @order.shipping_address.full_name %></p>
    <p class="text-sm"><%= @order.shipping_address.address_line1 %></p>
    <% if @order.shipping_address.address_line2.present? %>
      <p class="text-sm"><%= @order.shipping_address.address_line2 %></p>
    <% end %>
    <p class="text-sm"><%= @order.shipping_address.city %>, <%= @order.shipping_address.state %> <%= @order.shipping_address.postal_code %></p>
    <p class="text-sm"><%= @order.shipping_address.country %></p>
  </div>
</div>

<div class="mb-6 rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">Items</h2>
  <div class="overflow-x-auto">
  <table class="w-full min-w-[760px]">
    <thead class="bg-neutral-50 text-left text-sm">
      <tr>
        <th class="px-3 py-2">Product</th>
        <th class="px-3 py-2">Variant</th>
        <th class="px-3 py-2">Qty</th>
        <th class="px-3 py-2">Unit Price</th>
        <th class="px-3 py-2">Total</th>
      </tr>
    </thead>
    <tbody class="divide-y text-sm">
      <% @order.order_items.each do |item| %>
        <tr>
          <td class="px-3 py-2"><%= item.product.name %></td>
          <td class="px-3 py-2"><%= item.product_variant.size %> / <%= item.product_variant.color %></td>
          <td class="px-3 py-2"><%= item.quantity %></td>
          <td class="px-3 py-2"><%= number_to_currency(item.unit_price) %></td>
          <td class="px-3 py-2"><%= number_to_currency(item.total_price) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>

<div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-3 text-lg font-semibold">Update Status</h2>
  <%= form_with url: update_status_admin_order_path(@order), method: :patch, class: "flex flex-wrap items-end gap-3" do |f| %>
    <div>
      <%= f.label :status, class: "mb-1 block text-sm font-medium" %>
      <%= f.select :status, Order.statuses.keys.map { |status| [status.titleize, status] }, { selected: @order.status }, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>
    <%= f.submit "Update", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
  <% end %>
</div>
