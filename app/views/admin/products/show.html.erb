<div class="mb-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950"><%= @product.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_admin_product_path(@product), class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-4 py-2 font-semibold text-white" %>
    <%= link_to "Back", admin_products_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
  </div>
</div>

<div class="mb-6 grid gap-4 md:grid-cols-2">
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Product Details</h2>
    <dl class="space-y-2 text-sm">
      <div><dt class="font-medium">SKU</dt><dd><%= @product.sku %></dd></div>
      <div><dt class="font-medium">Category</dt><dd><%= @product.category&.name %></dd></div>
      <div><dt class="font-medium">Price</dt><dd><%= number_to_currency(@product.price) %></dd></div>
      <div><dt class="font-medium">Compare At</dt><dd><%= @product.compare_at_price.present? ? number_to_currency(@product.compare_at_price) : "-" %></dd></div>
      <div><dt class="font-medium">Gender</dt><dd><%= @product.gender.titleize %></dd></div>
      <div><dt class="font-medium">Brand</dt><dd><%= @product.brand.presence || "-" %></dd></div>
      <div><dt class="font-medium">Material</dt><dd><%= @product.material.presence || "-" %></dd></div>
      <div><dt class="font-medium">Status</dt><dd><span class="rounded-full px-2 py-1 text-xs <%= @product.active? ? 'bg-green-100 text-green-700' : 'bg-neutral-100 text-neutral-700' %>"><%= @product.active? ? "Active" : "Inactive" %></span></dd></div>
    </dl>
  </div>

  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Images</h2>
    <% if @product.product_images.any? %>
      <div class="grid grid-cols-2 gap-3">
        <% @product.product_images.each do |image| %>
          <div class="rounded-xl border border-neutral-200 p-2">
            <% if image.image.attached? %>
              <%= image_tag image.image, class: "h-32 w-full rounded object-cover" %>
            <% else %>
              <div class="flex h-32 items-center justify-center rounded bg-neutral-100 text-sm text-neutral-500">No image file</div>
            <% end %>
            <p class="mt-2 text-xs text-neutral-600"><%= image.alt_text.presence || "No alt text" %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-neutral-500">No images uploaded yet.</p>
    <% end %>
  </div>
</div>

<div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">Variants</h2>
  <div class="overflow-x-auto">
  <table class="w-full min-w-[700px]">
    <thead class="bg-neutral-50 text-left text-sm">
      <tr>
        <th class="px-3 py-2">SKU</th>
        <th class="px-3 py-2">Size</th>
        <th class="px-3 py-2">Color</th>
        <th class="px-3 py-2">Stock</th>
        <th class="px-3 py-2">Price Adj.</th>
        <th class="px-3 py-2">Active</th>
      </tr>
    </thead>
    <tbody class="divide-y text-sm">
      <% @product.product_variants.each do |variant| %>
        <tr>
          <td class="px-3 py-2"><%= variant.sku %></td>
          <td class="px-3 py-2"><%= variant.size %></td>
          <td class="px-3 py-2"><%= variant.color %></td>
          <td class="px-3 py-2"><%= variant.stock_quantity %></td>
          <td class="px-3 py-2"><%= number_to_currency(variant.additional_price) %></td>
          <td class="px-3 py-2"><span class="rounded-full px-2 py-1 text-xs <%= variant.active? ? 'bg-green-100 text-green-700' : 'bg-neutral-100 text-neutral-700' %>"><%= variant.active? ? "Yes" : "No" %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
