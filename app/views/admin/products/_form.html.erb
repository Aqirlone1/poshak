<div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with model: [:admin, product], html: { multipart: true }, class: "space-y-4" do |f| %>
    <% if product.errors.any? %>
      <div class="rounded border border-red-300 bg-red-50 p-3 text-sm text-red-700">
        <p class="font-semibold"><%= pluralize(product.errors.count, "error") %> prevented saving:</p>
        <ul class="mt-2 list-disc pl-5">
          <% product.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :name, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :sku, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :sku, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :price, class: "mb-1 block text-sm font-medium" %>
        <%= f.number_field :price, step: "0.01", class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :compare_at_price, class: "mb-1 block text-sm font-medium" %>
        <%= f.number_field :compare_at_price, step: "0.01", class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :category_id, "Category", class: "mb-1 block text-sm font-medium" %>
        <%= f.collection_select :category_id, Category.ordered, :id, :name, { prompt: "Select category" }, { class: "w-full rounded-xl border border-neutral-300 px-3 py-2" } %>
      </div>
      <div>
        <%= f.label :gender, class: "mb-1 block text-sm font-medium" %>
        <%= f.select :gender, Product.genders.keys.map { |key| [key.titleize, key] }, {}, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :brand, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :brand, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :material, class: "mb-1 block text-sm font-medium" %>
        <%= f.text_field :material, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
      <div>
        <%= f.label :position, class: "mb-1 block text-sm font-medium" %>
        <%= f.number_field :position, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
    </div>

    <div>
      <%= f.label :description, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_area :description, rows: 4, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :care_instructions, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_area :care_instructions, rows: 3, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :uploaded_images, "Product Images", class: "mb-1 block text-sm font-medium" %>
      <%= file_field_tag "product[uploaded_images][]", multiple: true, accept: "image/*", class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      <p class="mt-1 text-xs text-neutral-500">You can select multiple images.</p>
    </div>

    <% if product.product_images.any? %>
      <div>
        <p class="mb-2 text-sm font-medium">Existing Images</p>
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <% product.product_images.order(:position, :created_at).each do |product_image| %>
            <% next unless product_image.image.attached? %>
            <%= image_tag product_image.image, class: "h-28 w-full rounded border object-cover" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex gap-6">
      <label class="flex items-center gap-2 text-sm">
        <%= f.check_box :active %>
        Active
      </label>
      <label class="flex items-center gap-2 text-sm">
        <%= f.check_box :featured %>
        Featured
      </label>
    </div>

    <div class="flex gap-2">
      <%= f.submit class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
      <%= link_to "Cancel", admin_products_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
    </div>
  <% end %>
</div>
