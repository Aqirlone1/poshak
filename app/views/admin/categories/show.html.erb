<div class="mb-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950"><%= @category.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_admin_category_path(@category), class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-4 py-2 font-semibold text-white" %>
    <%= link_to "Back", admin_categories_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
  </div>
</div>

<div class="grid gap-4 md:grid-cols-2">
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Category Details</h2>
    <dl class="space-y-2 text-sm">
      <div><dt class="font-medium">Slug</dt><dd><%= @category.slug %></dd></div>
      <div><dt class="font-medium">Parent</dt><dd><%= @category.parent&.name || "-" %></dd></div>
      <div><dt class="font-medium">Position</dt><dd><%= @category.position %></dd></div>
      <div><dt class="font-medium">Active</dt><dd><span class="rounded-full px-2 py-1 text-xs <%= @category.active? ? 'bg-green-100 text-green-700' : 'bg-neutral-100 text-neutral-700' %>"><%= @category.active? ? "Yes" : "No" %></span></dd></div>
    </dl>
  </div>
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-3 text-lg font-semibold">Stats</h2>
    <p class="text-sm text-neutral-600">Products in this category</p>
    <p class="mt-2 text-3xl font-semibold"><%= @category.products.count %></p>
  </div>
</div>
