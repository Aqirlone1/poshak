<div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with model: [:admin, category], class: "space-y-4" do |f| %>
    <% if category.errors.any? %>
      <div class="rounded border border-red-300 bg-red-50 p-3 text-sm text-red-700">
        <p class="font-semibold"><%= pluralize(category.errors.count, "error") %> prevented saving:</p>
        <ul class="mt-2 list-disc pl-5">
          <% category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :name, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :slug, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :slug, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :description, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_area :description, rows: 4, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :parent_id, "Parent Category", class: "mb-1 block text-sm font-medium" %>
        <%= f.collection_select :parent_id, Category.where.not(id: category.id).ordered, :id, :name, { include_blank: "No parent" }, { class: "w-full rounded-xl border border-neutral-300 px-3 py-2" } %>
      </div>
      <div>
        <%= f.label :position, class: "mb-1 block text-sm font-medium" %>
        <%= f.number_field :position, class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
      </div>
    </div>

    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :active %>
      Active
    </label>

    <div class="flex gap-2">
      <%= f.submit class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
      <%= link_to "Cancel", admin_categories_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
    </div>
  <% end %>
</div>
