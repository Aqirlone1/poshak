<div class="mb-6 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">Admin Dashboard</h1>
  <p class="mt-1 text-sm text-violet-700">Control catalog, orders, customers, and performance from one place.</p>
</div>

<div class="mb-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
  <%= link_to "Add Product", new_admin_product_path, class: "rounded-2xl border border-neutral-200 bg-white p-3 text-center text-sm font-semibold shadow-sm hover:shadow-md" %>
  <%= link_to "Add Category", new_admin_category_path, class: "rounded-2xl border border-neutral-200 bg-white p-3 text-center text-sm font-semibold shadow-sm hover:shadow-md" %>
  <%= link_to "Manage Orders", admin_orders_path, class: "rounded-2xl border border-neutral-200 bg-white p-3 text-center text-sm font-semibold shadow-sm hover:shadow-md" %>
  <%= link_to "View Reports", admin_reports_path, class: "rounded-2xl border border-neutral-200 bg-white p-3 text-center text-sm font-semibold shadow-sm hover:shadow-md" %>
</div>

<div class="mb-6 grid gap-4 md:grid-cols-3">
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-neutral-500">Sales Today</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(@sales_by_day[Date.current] || 0) %></p>
  </div>
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-neutral-500">Sales This Week</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(@sales_by_day.select { |date, _| date >= Date.current.beginning_of_week }.values.sum) %></p>
  </div>
  <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-neutral-500">Sales This Month</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(@sales_by_day.select { |date, _| date >= Date.current.beginning_of_month }.values.sum) %></p>
  </div>
</div>

<div class="mb-6 rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-3 text-lg font-semibold">Sales Trend (Placeholder)</h2>
  <div class="flex h-56 items-center justify-center rounded border border-dashed text-neutral-500">
    Chart area for sales analytics
  </div>
</div>

<div class="grid gap-6 lg:grid-cols-2">
  <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Recent Orders</h2>
    <div class="overflow-x-auto">
    <table class="w-full min-w-[560px]">
      <thead class="bg-neutral-50 text-left text-sm">
        <tr>
          <th class="px-3 py-2">Order</th>
          <th class="px-3 py-2">Customer</th>
          <th class="px-3 py-2">Status</th>
          <th class="px-3 py-2">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y text-sm">
        <% @recent_orders.each do |order| %>
          <tr>
            <td class="px-3 py-2"><%= link_to order.order_number, admin_order_path(order), class: "underline" %></td>
            <td class="px-3 py-2"><%= order.user&.full_name.presence || order.user&.email %></td>
            <td class="px-3 py-2"><span class="rounded-full bg-neutral-100 px-2 py-1 text-xs"><%= order.status.titleize %></span></td>
            <td class="px-3 py-2"><%= number_to_currency(order.total_amount) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>

  <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Low Stock Alerts</h2>
    <div class="overflow-x-auto">
    <table class="w-full min-w-[500px]">
      <thead class="bg-neutral-50 text-left text-sm">
        <tr>
          <th class="px-3 py-2">Product</th>
          <th class="px-3 py-2">Variant SKU</th>
          <th class="px-3 py-2">Stock</th>
        </tr>
      </thead>
      <tbody class="divide-y text-sm">
        <% @low_stock_variants.each do |variant| %>
          <tr>
            <td class="px-3 py-2"><%= link_to variant.product.name, admin_product_path(variant.product), class: "underline" %></td>
            <td class="px-3 py-2"><%= variant.sku %></td>
            <td class="px-3 py-2"><span class="rounded-full bg-red-100 px-2 py-1 text-xs text-red-700"><%= variant.stock_quantity %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
</div>
