<div class="mb-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950"><%= @customer.full_name %></h1>
  <%= link_to "Back", admin_customers_path, class: "rounded-full border border-neutral-300 px-4 py-2" %>
</div>

<div class="mb-6 rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-2 text-lg font-semibold">Customer Details</h2>
  <p class="text-sm"><strong>Email:</strong> <%= @customer.email %></p>
  <p class="text-sm"><strong>Phone:</strong> <%= @customer.phone_number.presence || "-" %></p>
  <p class="text-sm"><strong>Joined:</strong> <%= l(@customer.created_at.to_date) %></p>
</div>

<div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">Recent Orders</h2>
  <div class="overflow-x-auto">
  <table class="w-full min-w-[640px]">
    <thead class="bg-neutral-50 text-left text-sm">
      <tr>
        <th class="px-3 py-2">Order</th>
        <th class="px-3 py-2">Status</th>
        <th class="px-3 py-2">Total</th>
        <th class="px-3 py-2">Date</th>
      </tr>
    </thead>
    <tbody class="divide-y text-sm">
      <% @orders.each do |order| %>
        <tr>
          <td class="px-3 py-2"><%= link_to order.order_number, admin_order_path(order), class: "font-semibold hover:text-fuchsia-700" %></td>
          <td class="px-3 py-2"><span class="rounded-full bg-neutral-100 px-2 py-1 text-xs"><%= order.status.titleize %></span></td>
          <td class="px-3 py-2"><%= number_to_currency(order.total_amount) %></td>
          <td class="px-3 py-2"><%= l(order.created_at.to_date) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
