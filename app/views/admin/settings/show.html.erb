<div class="mb-6 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">Store Settings</h1>
</div>

<div class="max-w-2xl rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with url: admin_settings_path, method: :patch, scope: :settings, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :site_name, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :site_name, value: @settings[:site_name], class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :support_email, class: "mb-1 block text-sm font-medium" %>
      <%= f.email_field :support_email, value: @settings[:support_email], class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    </div>
    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :cod_enabled, { checked: @settings[:cod_enabled] }, "true", "false" %>
      Cash on delivery enabled
    </label>
    <label class="flex items-center gap-2 text-sm">
      <%= f.check_box :maintenance_mode, { checked: @settings[:maintenance_mode] }, "true", "false" %>
      Maintenance mode
    </label>
    <%= f.submit "Save Settings", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
  <% end %>
</div>
