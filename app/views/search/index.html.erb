<div class="mb-6 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">Search Products</h1>
</div>

<div class="mb-6 rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
  <%= form_with url: search_path, method: :get, local: true, class: "flex gap-2" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search by name, SKU, category", class: "w-full rounded-xl border border-neutral-300 px-3 py-2" %>
    <%= f.submit "Search", class: "rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-5 py-2 font-semibold text-white" %>
  <% end %>
</div>

<div class="grid gap-4 md:grid-cols-3">
  <% @products.each do |product| %>
    <%= link_to product_path(product), class: "rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-lg" do %>
      <h2 class="font-semibold"><%= product.name %></h2>
      <p class="text-sm text-neutral-600"><%= product.category&.name %></p>
      <p class="mt-2 font-medium"><%= number_to_currency(product.price) %></p>
    <% end %>
  <% end %>
</div>

<div class="mt-6">
  <%= paginate @products if @products.respond_to?(:current_page) %>
</div>
