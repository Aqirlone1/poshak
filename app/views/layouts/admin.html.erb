<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Poshak Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-neutral-50 text-neutral-900">
    <header class="sticky top-0 z-30 border-b border-neutral-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4">
          <%= link_to admin_dashboard_path, class: "flex items-center gap-2" do %>
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-violet-700 to-fuchsia-600 text-xs font-bold text-white">A</span>
            <span class="font-semibold">Poshak Admin</span>
          <% end %>
          <nav class="flex flex-wrap items-center gap-2 text-sm">
            <%= link_to "Dashboard", admin_dashboard_path, class: "rounded-full px-3 py-1.5 #{request.path == admin_dashboard_path ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Products", admin_products_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_products_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Categories", admin_categories_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_categories_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Orders", admin_orders_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_orders_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Customers", admin_customers_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_customers_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Reports", admin_reports_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_reports_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
            <%= link_to "Settings", admin_settings_path, class: "rounded-full px-3 py-1.5 #{request.path.start_with?(admin_settings_path) ? 'bg-neutral-900 text-white' : 'text-neutral-700 hover:bg-neutral-100'}" %>
          </nav>
        </div>
        <%= link_to "Storefront", root_path, class: "rounded-full border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
      </div>
    </header>
    <%= render "shared/flash" %>
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
