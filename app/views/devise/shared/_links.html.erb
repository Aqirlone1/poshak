<div class="space-y-2 text-sm">
  <% if controller_name != "sessions" %>
    <%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "text-neutral-700 hover:text-black" %><br>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "New here? Create an account", new_registration_path(resource_name), class: "text-neutral-700 hover:text-black" %><br>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-neutral-700 hover:text-black" %><br>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <%= link_to "Resend confirmation instructions", new_confirmation_path(resource_name), class: "text-neutral-700 hover:text-black" %><br>
  <% end %>
</div>
