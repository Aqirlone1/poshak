<section class="mx-auto max-w-md py-10">
  <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm">
    <h1 class="mb-1 text-2xl font-semibold">Welcome back</h1>
    <p class="mb-6 text-sm text-neutral-600">Sign in to continue shopping at Poshak.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded border border-neutral-300 px-3 py-2 outline-none ring-black focus:ring-1" %>
      </div>

      <div>
        <%= f.label :password, class: "mb-1 block text-sm font-medium" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded border border-neutral-300 px-3 py-2 outline-none ring-black focus:ring-1" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm text-neutral-700">
          <%= f.check_box :remember_me, class: "rounded border-neutral-300" %>
          Remember me
        </label>
      <% end %>

      <%= f.submit "Sign in", class: "w-full rounded bg-black px-4 py-2 font-medium text-white hover:bg-neutral-800" %>
    <% end %>

    <div class="mt-5 border-t pt-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
