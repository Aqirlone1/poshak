<section class="mx-auto max-w-md py-10">
  <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm">
    <h1 class="mb-1 text-2xl font-semibold">Forgot password?</h1>
    <p class="mb-6 text-sm text-neutral-600">Enter your email to receive reset instructions.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded border border-neutral-300 px-3 py-2 outline-none focus:ring-1 focus:ring-black" %>
      </div>
      <%= f.submit "Send reset instructions", class: "w-full rounded bg-black px-4 py-2 font-medium text-white hover:bg-neutral-800" %>
    <% end %>

    <div class="mt-5 border-t pt-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
