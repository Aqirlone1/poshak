<article class="group overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
  <div class="relative aspect-[4/5] bg-gradient-to-br from-fuchsia-100 via-violet-100 to-cyan-100">
    <% if product.primary_image&.image&.attached? %>
      <%= image_tag product.primary_image.image, class: "h-full w-full object-cover" %>
    <% end %>
    <span class="absolute left-3 top-3 rounded-full bg-black px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-white">New</span>
  </div>
  <div class="p-4">
    <h3 class="text-sm font-semibold text-neutral-900"><%= product.name %></h3>
    <p class="mt-1 text-sm text-neutral-600">INR <%= product.price %></p>
    <div class="mt-3">
      <%= link_to "View Product", product_path(product), class: "inline-block rounded-full bg-gradient-to-r from-violet-700 to-fuchsia-600 px-4 py-1.5 text-xs font-semibold text-white" %>
    </div>
  </div>
</article>
