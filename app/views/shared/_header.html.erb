<header class="sticky top-0 z-30 border-b border-neutral-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8">
    <%= link_to root_path, class: "flex items-center gap-2" do %>
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-violet-700 to-fuchsia-600 text-xs font-bold text-white">P</span>
      <span class="text-lg font-bold tracking-wide">Poshak</span>
    <% end %>

    <nav class="hidden items-center gap-2 md:flex">
      <%= link_to "Home", root_path, class: nav_link_classes(nav_active_for?(:home)) %>
      <%= link_to "Products", products_path, class: nav_link_classes(nav_active_for?(:products)) %>
      <%= link_to "Categories", categories_path, class: nav_link_classes(nav_active_for?(:categories)) %>
      <%= link_to "Wishlist", wishlists_path, class: nav_link_classes(nav_active_for?(:wishlist)) %>
      <%= link_to "Cart", cart_path, class: nav_link_classes(request.path.start_with?(cart_path)) %>
      <% if user_signed_in? %>
        <%= link_to "Account", account_dashboard_path, class: nav_link_classes(nav_active_for?(:account)) %>
        <% if current_user.admin? %>
          <%= link_to "Admin", admin_dashboard_path, class: "rounded-full px-3 py-1.5 text-sm font-semibold text-violet-700 hover:bg-violet-50" %>
        <% end %>
        <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "rounded-full border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "rounded-full border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
      <% end %>
    </nav>

    <details class="relative md:hidden">
      <summary class="list-none cursor-pointer rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700">Menu</summary>
      <div class="absolute right-0 mt-2 w-64 rounded-2xl border border-neutral-200 bg-white p-3 shadow-xl">
        <nav class="space-y-1">
          <%= link_to "Home", root_path, class: nav_link_mobile_classes(nav_active_for?(:home)) %>
          <%= link_to "Products", products_path, class: nav_link_mobile_classes(nav_active_for?(:products)) %>
          <%= link_to "Categories", categories_path, class: nav_link_mobile_classes(nav_active_for?(:categories)) %>
          <%= link_to "Wishlist", wishlists_path, class: nav_link_mobile_classes(nav_active_for?(:wishlist)) %>
          <%= link_to "Cart", cart_path, class: nav_link_mobile_classes(request.path.start_with?(cart_path)) %>
          <% if user_signed_in? %>
            <%= link_to "Account", account_dashboard_path, class: nav_link_mobile_classes(nav_active_for?(:account)) %>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_dashboard_path, class: "block rounded-xl px-3 py-2 text-sm font-semibold text-violet-700 hover:bg-violet-50" %>
            <% end %>
            <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "block rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
          <% else %>
            <%= link_to "Login", new_user_session_path, class: "block rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
          <% end %>
        </nav>
      </div>
    </details>
  </div>
</header>
