<% if notice.present? || alert.present? %>
  <div class="mx-auto mt-4 max-w-7xl px-4 sm:px-6 lg:px-8">
    <% if notice.present? %>
      <div class="mb-2 rounded border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= alert %></div>
    <% end %>
  </div>
<% end %>
