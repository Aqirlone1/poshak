<div class="mb-6 rounded-2xl border border-fuchsia-100 bg-gradient-to-r from-violet-50 via-fuchsia-50 to-pink-50 p-5">
  <h1 class="text-3xl font-bold text-violet-950">Shop by Category</h1>
</div>

<div class="grid gap-4 md:grid-cols-3">
  <% @categories.each do |category| %>
    <%= link_to category_path(category), class: "rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-lg" do %>
      <h2 class="text-lg font-bold"><%= category.name %></h2>
      <p class="mt-1 text-sm text-neutral-600"><%= truncate(category.description, length: 90) %></p>
      <p class="mt-3 text-sm font-medium">Browse products</p>
    <% end %>
  <% end %>
</div>
